{
  "name": "searxng-tools",
  "version": "1.0.0",
  "description": "Universal SearXNG search tools for AI agents and OpenClaw - free, private web search",
  "main": "src/index.ts",
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "searxng",
    "search",
    "privacy"
  ],
  "author": "OpenClaw User",
  "license": "MIT",
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "jsdom": "^24.0.0",
    "turndown": "^7.1.2"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.6",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0",
    "vitest-fetch-mock": "^0.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
