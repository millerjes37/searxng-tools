{
  "id": "searxng-search",
  "name": "SearXNG Search",
  "version": "1.0.0",
  "description": "Free, private web search using SearXNG (89+ search engines). Drop-in replacement for OpenClaw's built-in web tools.",
  "author": "OpenClaw Plugin",
  "license": "MIT",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "searxngUrl": {
        "type": "string",
        "default": "http://localhost:8888",
        "description": "SearXNG instance URL"
      },
      "defaultMaxResults": {
        "type": "number",
        "default": 10,
        "minimum": 1,
        "maximum": 50,
        "description": "Default number of results to return"
      },
      "timeoutSeconds": {
        "type": "number",
        "default": 30,
        "minimum": 5,
        "maximum": 120,
        "description": "Request timeout in seconds"
      },
      "cacheResults": {
        "type": "boolean",
        "default": true,
        "description": "Enable result caching"
      },
      "cacheTtlMinutes": {
        "type": "number",
        "default": 15,
        "minimum": 1,
        "maximum": 60,
        "description": "Cache TTL in minutes"
      },
      "disableBuiltinWebTools": {
        "type": "boolean",
        "default": true,
        "description": "Automatically disable built-in web search/fetch tools"
      },
      "logLevel": {
        "type": "string",
        "enum": ["error", "warn", "info", "debug"],
        "default": "info",
        "description": "Logging level"
      }
    }
  },
  "uiHints": {
    "searxngUrl": {
      "label": "SearXNG URL",
      "placeholder": "http://localhost:8888"
    },
    "defaultMaxResults": {
      "label": "Default Max Results"
    },
    "timeoutSeconds": {
      "label": "Timeout (seconds)"
    },
    "cacheResults": {
      "label": "Enable Caching"
    },
    "cacheTtlMinutes": {
      "label": "Cache TTL (minutes)"
    },
    "disableBuiltinWebTools": {
      "label": "Disable Built-in Web Tools"
    },
    "logLevel": {
      "label": "Log Level"
    }
  }
}
